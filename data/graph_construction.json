  "special_cases": [
    {
      "node": "ProductPlant",
      "type": "JUNCTION_WITH_ATTRIBUTES",
      "description": "ProductPlant connects Product and Plant in a MANY_TO_MANY relationship. It contains 3 additional non-FK attributes (availability_check_type, mrp_type, profit_center), so it is retained as a node rather than collapsed into a single MANY_TO_MANY edge.",
      "effective_cardinality": "MANY_TO_MANY",
      "stats": "69 products × 44 plants = 3,036 product-plant combinations"
    },
    {
      "node": "BillingDocumentItem",
      "type": "MULTI_BILLED_DELIVERY_ITEMS",
      "description": "121 out of 137 delivery items appear in 2 billing document items each. In every case, one billing document is cancelled (is_cancelled=true) and one is active. This represents the SAP cancellation-rebilling pattern: original invoice → cancel → reissue. Query logic must filter is_cancelled=false for current billing state.",
      "affected_edge": "BillingDocumentItem → OutboundDeliveryItem"
    },
    {
      "node": "SalesOrderScheduleLine",
      "type": "PARTIAL_KEY_DEPENDENCY",
      "description": "12 SalesOrderItems have 2 schedule lines with different confirmed_delivery_date and confirmed_quantity values, representing partial delivery confirmation (some quantity confirmed on one date, remainder on another). The latest non-zero schedule line represents the effective delivery commitment.",
      "affected_edge": "SalesOrderScheduleLine → SalesOrderItem"
    },
    {
      "edge": "JournalEntry → BillingDocument",
      "type": "DUAL_PATH",
      "description": "Two valid join paths exist between JournalEntry and BillingDocument: (1) via accounting_document_id (alternate key) for the posting relationship, and (2) via reference_billing_document_id = billing_document_id for the reference relationship. Both are validated in data. Prefer path (2) for direct invoice tracing."
    }
  ],
  "o2c_primary_path": {
